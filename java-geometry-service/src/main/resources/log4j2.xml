<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Properties>
        <Property name="logDir">${sys:user.dir}/logs</Property>
        <Property name="logPattern">%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%t] %c{1.} - %msg%n</Property>
    </Properties>
    <Appenders>
        <Console name="Console" target="SYSTEM_ERR">
            <PatternLayout pattern="${logPattern}"/>
        </Console>
        <RollingFile name="GeometryFile"
                     fileName="${logDir}/geometry-runtime.log"
                     filePattern="${logDir}/geometry-runtime-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="${logPattern}"/>
            <Policies>
                <SizeBasedTriggeringPolicy size="10 MB"/>
            </Policies>
            <DefaultRolloverStrategy max="10"/>
        </RollingFile>
    </Appenders>
    <Loggers>
        <Logger name="com.example.iml" level="info" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="GeometryFile"/>
        </Logger>
        <Root level="warn">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="GeometryFile"/>
        </Root>
    </Loggers>
</Configuration>
